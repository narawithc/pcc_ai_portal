# PCC AI Portal — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าจริง
# cp .env.example .env

# ============================================================
# Anthropic API (Required)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxxx

# ============================================================
# Database
# ============================================================
POSTGRES_USER=pcc_admin
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=pcc_ai

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=changeme_redis_password

# ============================================================
# LiteLLM
# ============================================================
LITELLM_MASTER_KEY=sk-pcc-master-changeme

# ============================================================
# Open WebUI
# ============================================================
WEBUI_SECRET_KEY=changeme-webui-secret-32chars

# ============================================================
# Backend / JWT
# ============================================================
SECRET_KEY=changeme-jwt-secret-32chars

# AUTH_MODE: prod = Azure AD required (default); dev = mock users (local only)
# WARNING: prod mode requires SECRET_KEY to be set — server exits on startup otherwise
AUTH_MODE=prod

# ============================================================
# Encryption (Provider Credentials)
# สร้าง key ด้วย: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================
ENCRYPTION_KEY=

# ============================================================
# Azure AD — รอ IT Admin (ใส่เมื่อได้รับ)
# ============================================================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ============================================================
# Security secrets for internal endpoints
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Optional but strongly recommended for production
# ============================================================
INTERNAL_SECRET=
LITELLM_CALLBACK_SECRET=

# Pipelines internal API key
PIPELINES_API_KEY=changeme-pipelines-key

# LiteLLM default team ID for new users (basic tier)
# Get from LiteLLM UI → Teams → copy team_id
LITELLM_DEFAULT_TEAM_ID=

# ============================================================
# Incident Email (AI Policy Section 10)
# ============================================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@precise.co.th
SMTP_PASSWORD=changeme_smtp_password
INCIDENT_EMAIL=ai-report@precise.co.th

# ============================================================
# Policy Version (bump when policy is updated)
# ============================================================
POLICY_VERSION=v1.0

# ============================================================
# Monitoring (used with: docker compose --profile monitoring up -d)
# ============================================================

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=changeme-grafana-password

# PostgreSQL exporter DSN (defaults to main DB if left blank)
# Format: postgresql://user:password@host:5432/dbname?sslmode=disable
POSTGRES_EXPORTER_DSN=postgresql://pcc_admin:changeme_strong_password@postgres:5432/pcc_ai?sslmode=disable
